<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/2.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/2.0.0 https://raw.githubusercontent.com/spotbugs/filter/master/src/main/resources/filter.xsd">

    <!-- Exclude Generated MapStruct Mappers -->
    <Match>
        <Class name="~.*MapperImpl.*" />
    </Match>

    <!-- Exclude Test Files from Bug Analysis -->
    <Match>
        <Class name="~.*Test.*" />
    </Match>

    <!-- Exclude Lombok Builder class segments -->
    <Match>
        <Class name="~.*Builder.*" />
    </Match>
</FindBugsFilter>
